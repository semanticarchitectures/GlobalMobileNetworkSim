          "expectedTimeSec": 6100
        },
        {
          "actionType": "RECOVERY_COMPLETE",
          "triggerEvent": "recovery_done",
          "expectedTimeSec": 6600
        }
      ]
    },

    {
      "role": "Air_Traffic_Management",
      "ordering": "unordered",
      "actions": [
        {
          "actionType": "FLIGHT_PLAN_ACKNOWLEDGED",
          "triggerEvent": "flight_plan_received",
          "expectedTimeSec": 120
        },
        {
          "actionType": "AIRSPACE_RESERVED",
