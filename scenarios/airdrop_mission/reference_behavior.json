{
  "scenarioName": "AirdropMission",
  "roles": [
    {
      "role": "Aircrew",
      "ordering": "strict",
      "actions": [
        {
          "actionType": "DEPARTURE_REPORT",
          "triggerEvent": "mission_start",
          "expectedTimeSec": 120
        },
        {
          "actionType": "POSITION_REPORT",
          "triggerEvent": "en_route_15min",
          "expectedTimeSec": 1020
        },
        {
          "actionType": "POSITION_REPORT",
          "triggerEvent": "en_route_30min",
          "expectedTimeSec": 2020
        },
        {
          "actionType": "POSITION_REPORT",
          "triggerEvent": "en_route_45min",
          "expectedTimeSec": 3020
        },
        {
          "actionType": "POSITION_REPORT",
          "triggerEvent": "en_route_60min",
          "expectedTimeSec": 4020
        },
        {
          "actionType": "THIRTY_MIN_ADVISORY",
          "triggerEvent": "approach_30min",
          "expectedTimeSec": 4800
        },
        {
          "actionType": "REQUEST_DZ_STATUS",
          "triggerEvent": "approach_30min",
          "expectedTimeSec": 4800
        },
        {
          "actionType": "REQUEST_AIRSPACE_CLEARANCE",
          "triggerEvent": "approach_30min",
          "expectedTimeSec": 4800
